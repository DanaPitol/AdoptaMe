<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Base.Theme.Adoptame" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/adoptame_orange</item>
        <item name="android:statusBarColor">@color/adoptame_background</item>
        <item name="android:navigationBarColor">@color/adoptame_background</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.Adoptame" parent="Base.Theme.Adoptame" />

    <style name="AuthLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/adoptame_text_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AuthInput">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:background">@drawable/ic_input_background</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:textColor">@color/adoptame_text_primary</item>
        <item name="android:textColorHint">@color/adoptame_text_hint</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="AuthPrimaryButton" parent="Widget.AppCompat.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:background">@drawable/ic_button_primary_background</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
